# terraform.tfvars.example
# =====================================================================
# Copy this file to terraform.tfvars and fill in your real values.
# DO NOT commit terraform.tfvars to git — add it to .gitignore!
# =====================================================================

# AWS region to deploy into
aws_region = "us-east-1"

# S3 bucket name for document storage.
# Must be globally unique — change the suffix to your own value.
s3_bucket_name = "procurement-dev-documents-YOURNAME"

# --- Filled in AFTER Phase 3 (Baking AMIs) ---
# Replace these placeholder values with your actual AMI IDs.
frontend_ami_id = "ami-xxxxxxxxxxxxxxxxx"
backend_ami_id  = "ami-xxxxxxxxxxxxxxxxx"

# KMS key ARN — leave empty to auto-create via Terraform
# (Terraform creates the key; fill this in only if using a pre-existing key)
kms_key_arn = ""
