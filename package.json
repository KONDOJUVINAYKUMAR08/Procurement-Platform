{
  "name": "procurement-platform-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend/shared/*",
    "backend/services/*",
    "backend/gateway/*",
    "frontend"
  ],
  "scripts": {
    "bootstrap": "npm install",
    "dev:gateway": "npm run dev -w api-gateway",
    "dev:frontend": "npm run start -w frontend",
    "dev": "concurrently \"npm run dev:gateway\" \"npm run dev:frontend\"",
    "build:backend": "npm run build --workspace=@procurement/types --workspace=@procurement/common --workspace=@procurement/utils --workspace=@procurement/middleware --workspace=@procurement/identity-service --workspace=@procurement/procurement-service --workspace=@procurement/finance-service --workspace=@procurement/document-service --workspace=api-gateway --if-present",
    "build:frontend": "npm run build -w frontend",
    "build": "npm run build:backend && npm run build:frontend",
    "seed": "ts-node backend/scripts/seed.ts",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/joi": "^17.2.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.2",
    "@types/uuid": "^10.0.0",
    "ajv": "^8.20.0",
    "ajv-keywords": "^5.1.0",
    "aws-sdk": "^2.1693.0",
    "concurrently": "^8.2.2",
    "esbuild": "^0.28.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1063.0",
    "@aws-sdk/lib-dynamodb": "^3.1063.0",
    "bcryptjs": "^3.0.3",
    "dynamoose": "^4.2.0",
    "express": "^5.2.1",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "winston": "^3.19.0"
  }
}
