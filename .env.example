# ── ProcureFlow — Local Development Environment ─────────────────────────────
# Copy this file to .env and fill in your values

# Node
NODE_ENV=development
PORT=5000

# ── DynamoDB Local ────────────────────────────────────────────────────────────
# When running docker compose locally, this points to the DynamoDB Local container
DYNAMODB_LOCAL_ENDPOINT=http://localhost:8000

# ── AWS (required for production / S3 uploads — uses EC2 IAM role) ────────────
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-procurement-bucket-name

# Optional: KMS key for S3 server-side encryption (leave blank to disable)
AWS_KMS_KEY_ID=

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_secure_random_string_at_least_32_chars
JWT_REFRESH_SECRET=change_this_to_another_secure_random_string_at_least_32_chars
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── SMTP (optional — for password reset emails) ───────────────────────────────
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@procureflow.com
